def ensure_cache_dir():
    ensure_index_dir()
    os.makedirs(CACHE_DIR, exist_ok=True)

def file_sig(path):
    st = os.stat(path)
    return f"{path}:{int(st.st_mtime)}:{st.st_size}"

def cache_key(path):
    h = hashlib.sha1(path.encode("utf-8")).hexdigest()
    base = os.path.join(CACHE_DIR, h)
    return {
        "chunks": base + ".chunks.json",
        "emb":    base + ".emb.npy",
        "meta":   base + ".meta.json",
    }

def load_cached_file(path):
    keys = cache_key(path)
    if not (os.path.exists(keys["chunks"]) and os.path.exists(keys["emb"]) and os.path.exists(keys["meta"])):
        return None, None
    meta = json.load(open(keys["meta"]))
    # back-compat: if 'path' missing, treat as stale
    if meta.get("path") != os.path.abspath(path):
        return None, None
    if meta.get("sig") != file_sig(path):
        return None, None
    try:
        chunks = json.load(open(keys["chunks"]))
        embs = np.load(keys["emb"])
        return chunks, embs
    except Exception:
        return None, None

def save_cached_file(path, chunks, embs):
    keys = cache_key(path)
    json.dump(chunks, open(keys["chunks"], "w"))
    np.save(keys["emb"], embs)
    json.dump({"sig": file_sig(path), "path": os.path.abspath(path)}, open(keys["meta"], "w"))


def _match_any(name: str, patterns: Iterable[str]) -> bool:
    name_lower = name.lower()
    return any(fnmatch.fnmatch(name_lower, p.lower()) for p in patterns)

def md_files(root=".", recursive=False, exts=DEFAULT_EXTS, ignores=DEFAULT_IGNORES):
    root = os.path.abspath(root)
    out = []
    if not recursive:
        for f in os.listdir(root):
            path = os.path.join(root, f)
            if os.path.isfile(path) and _match_any(f, exts):
                out.append(path)
        return sorted(out)

    for dirpath, dirnames, filenames in os.walk(root):
        # prune ignored dirs
        dirnames[:] = [d for d in dirnames if d not in ignores]
        for f in filenames:
            if _match_any(f, exts):
                path = os.path.join(dirpath, f)
                if os.path.isfile(path):
                    out.append(path)
    return sorted(out)
    
def file_sig(path):
    st = os.stat(path)
    return f"{path}:{int(st.st_mtime)}:{st.st_size}"

def ensure_index_dir():
    os.makedirs(INDEX_DIR, exist_ok=True)

    
def embed_texts(model, texts):
    return model.encode(texts, batch_size=64, show_progress_bar=False, normalize_embeddings=True)
    
def chunk_text(text, filename):
    # Prefer splitting on headings; then window if needed.
    sections = re.split(r"(?m)^#{1,6}\s+", text)
    chunks = []
    for sec in sections:
        sec = sec.strip()
        if not sec:
            continue
        # further windowing by chars
        i = 0
        while i < len(sec):
            chunk = sec[i:i+CHUNK_SIZE]
            chunks.append(chunk)
            i += CHUNK_SIZE - CHUNK_OVERLAP
    # attach simple titles from preceding headings for context
    # (rough but effective)
    lines = text.splitlines()
    titles = []
    for i,l in enumerate(lines):
        if re.match(r"^#{1,6}\s+", l):
            titles.append((i, l.strip("# ").strip()))
    def nearest_title(pos):
        prev = [t for t in titles if t[0] <= pos]
        return prev[-1][1] if prev else pathlib.Path(filename).stem
    out = []
    pos = 0
    for c in chunks:
        # Find rough position to guess heading
        snippet_start = text.find(c, pos)
        title = nearest_title(snippet_start if snippet_start>=0 else pos)
        out.append({"file": filename, "title": title, "text": c})
        pos = (snippet_start + len(c)) if snippet_start>=0 else pos + len(c)
    return out

def build_corpus():
    data = []
    sigs = []
    for f in md_files():
        with open(f, "r", encoding="utf-8", errors="ignore") as fh:
            txt = fh.read()
        ch = chunk_text(txt, f)
        data.extend(ch)
        sigs.append(file_sig(f))
    return data, sigs

def load_or_build_index(force=False, root=".", recursive=False, exts=DEFAULT_EXTS):
    ensure_cache_dir()
    meta_path = os.path.join(INDEX_DIR, "meta.json")
    idx_path  = os.path.join(INDEX_DIR, "index.faiss")
    map_path  = os.path.join(INDEX_DIR, "map.json")

    files = md_files(root=root, recursive=recursive, exts=exts)
    if not files:
        raise SystemExit("No Markdown/Rmarkdown files found.")

    current_sigs = [file_sig(f) for f in files]
    if (not force and os.path.exists(meta_path) and os.path.exists(idx_path) and os.path.exists(map_path)):
        meta = json.load(open(meta_path))
        if meta.get("sigs") == current_sigs:
            index = faiss.read_index(idx_path)
            mapping = json.load(open(map_path))
            return index, mapping

    console.print("[bold]Indexing (incremental)...[/bold]")
    model = SentenceTransformer(EMB_MODEL)

    all_chunks = []
    all_embs = []

    for f in files:
        chunks, embs = (None, None) if force else load_cached_file(f)
        if chunks is None or embs is None:
            with open(f, "r", encoding="utf-8", errors="ignore") as fh:
                txt = fh.read()
            chunks = chunk_text(txt, f)
            texts = [c["text"] for c in chunks]
            embs = embed_texts(model, texts)
            save_cached_file(f, chunks, embs)
        all_chunks.extend(chunks)
        all_embs.append(embs)

    if not all_embs:
        raise SystemExit("No content to index.")
    embs = np.vstack(all_embs).astype("float32")

    index = faiss.IndexFlatIP(embs.shape[1])
    index.add(embs)

    faiss.write_index(index, idx_path)
    json.dump({"sigs": current_sigs, "emb_model": EMB_MODEL, "ts": time.time(), "root": os.path.abspath(root),
               "recursive": bool(recursive), "exts": list(exts)}, open(meta_path, "w"))
    json.dump(all_chunks, open(map_path, "w"))
    return index, all_chunks

def retrieve(query, top_k=TOP_K):
    index, mapping = load_or_build_index(force=False)
    model = SentenceTransformer(EMB_MODEL)
    q = model.encode([query], normalize_embeddings=True)
    D, I = index.search(q, top_k)
    hits = []
    for rank, (score, idx) in enumerate(zip(D[0], I[0]), start=1):
        if idx == -1: continue
        item = mapping[idx]
        hits.append({"rank": rank, "score": float(score), **item})
    return hits

def call_llm(prompt):
    # Optional: use OpenAI if key is present; otherwise None
    api_key = os.environ["OPENAI_API_KEY"]
    if not api_key:
        return None
    try:
        from openai import OpenAI
        client = OpenAI(api_key=api_key)
        # compact system prompt
        sys_prompt = (
            "You answer questions strictly using the provided context. "
            "Cite file names and headings when possible."
        )
        resp = client.chat.completions.create(
            model=os.environ.get("OPENAI_MODEL", "gpt-4o-mini"),
            messages=[
                {"role":"system","content":sys_prompt},
                {"role":"user","content":prompt},
            ],
            temperature=0.1,
        )
        return resp.choices[0].message.content.strip()
    except Exception as e:
        return f"(LLM call failed: {e})"

def make_prompt(query, hits):
    ctx_parts = []
    for h in hits:
        header = f"[{h['file']} :: {h['title']}]"
        ctx_parts.append(header + "\n" + h["text"])
    ctx = "\n\n---\n\n".join(ctx_parts)
    return (
        f"Context from local Markdown files:\n\n{ctx}\n\n"
        f"Question: {query}\n\n"
        "Answer concisely and cite files/sections like [file :: heading]."
    )

@click.group(context_settings=dict(help_option_names=["-h","--help"]))
def cli():
    """ragmd: chat with the Markdown/Rmarkdown in your current directory (or subtree)."""
    pass

@cli.command()
@click.option("--root", default=".", show_default=True, help="root directory to scan")
@click.option("--recursive", is_flag=True, help="recurse into subdirectories")
@click.option("--ext", "exts", multiple=True, help="extra glob(s) for file extensions, e.g. --ext '*.qmd'")
def index(root, recursive, exts):
    """Build or refresh the local index."""
    # combine defaults with user-supplied exts
    effective_exts = DEFAULT_EXTS + tuple(exts) if exts else DEFAULT_EXTS
    load_or_build_index(force=True, root=root, recursive=recursive, exts=effective_exts)
    console.print("[green]Index built.[/green]")

@cli.command()
@click.argument("question", nargs=-1)
@click.option("--top-k", default=TOP_K, show_default=True, help="number of passages")
@click.option("--no-llm", is_flag=True, help="skip LLM; show retrieved snippets only")
@click.option("--root", default=".", show_default=True, help="root directory to scan")
@click.option("--recursive", is_flag=True, help="recurse into subdirectories")
@click.option("--ext", "exts", multiple=True, help="extra glob(s) for file extensions")
def ask(question, top_k, no_llm, root, recursive, exts):
    """Ask a question about your local Markdown/Rmarkdown."""
    q = " ".join(question).strip()
    if not q:
        raise SystemExit('Provide a question, e.g. `ragmd ask "Where did I compute PCA?"`')
    effective_exts = DEFAULT_EXTS + tuple(exts) if exts else DEFAULT_EXTS
    # ensure index exists / up-to-date
    index, mapping = load_or_build_index(force=False, root=root, recursive=recursive, exts=effective_exts)
    # retrieval as before
    model = SentenceTransformer(EMB_MODEL)
    D, I = index.search(model.encode([q], normalize_embeddings=True), top_k)
    hits = []
    for rank, (score, idx) in enumerate(zip(D[0], I[0]), start=1):
        if idx == -1: continue
        item = mapping[idx]
        hits.append({"rank": rank, "score": float(score), **item})
    prompt = make_prompt(q, hits)
    if no_llm:
        console.rule("[bold]Top matches[/bold]")
        for h in hits:
            console.print(f"[{h['rank']}] {h['file']} :: {h['title']}  (score={h['score']:.3f})")
            console.print(Markdown(h["text"].strip()[:1000] + ("..." if len(h["text"])>1000 else "")))
            console.print("")
        return
    answer = call_llm(prompt)
    if answer:
        console.rule("[bold]Answer[/bold]")
        console.print(Markdown(answer))
        console.rule("[bold]Sources[/bold]")
    for h in hits:
        console.print(f"[{h['rank']}] {h['file']} :: {h['title']}  (score={h['score']:.3f})")

@cli.command()
def vacuum():
    """Remove cached vectors for files that no longer exist or moved; then rebuild index."""
    ensure_cache_dir()
    removed = 0
    for fname in os.listdir(CACHE_DIR):
        if not fname.endswith(".meta.json"):
            continue
        meta_path = os.path.join(CACHE_DIR, fname)
        try:
            meta = json.load(open(meta_path))
            path = meta.get("path")
        except Exception:
            path = None
        if (not path) or (not os.path.exists(path)):
            # delete this cache bundle
            base = meta_path[:-10]  # strip ".meta.json"
            for ext in (".meta.json", ".chunks.json", ".emb.npy"):
                f = base + ext
                if os.path.exists(f):
                    os.remove(f)
            removed += 1
    console.print(f"[green]Vacuum complete.[/green] Removed {removed} stale cache entr{'y' if removed==1 else 'ies'}.")

@cli.command()
@click.option("--root", default=".", show_default=True, help="root directory to scan")
@click.option("--recursive", is_flag=True, help="recurse into subdirectories")
@click.option("--ext", "exts", multiple=True, help="extra glob(s) for file extensions")
def stats(root, recursive, exts):
    """Show basic index stats."""
    effective_exts = DEFAULT_EXTS + tuple(exts) if exts else DEFAULT_EXTS
    files = md_files(root=root, recursive=recursive, exts=effective_exts)
    n_files = len(files)
    n_cached = 0
    n_chunks = 0
    for f in files:
        chunks, embs = load_cached_file(f)
        if chunks is not None and embs is not None:
            n_cached += 1
            n_chunks += len(chunks)
    console.print(f"Files discovered: {n_files}")
    console.print(f"Files cached:     {n_cached}")
    console.print(f"Total chunks:     {n_chunks} (cached)")

if __name__ == "__main__":
    cli()
