def make_prompt(query, hits):
    ctx_parts = []
    for h in hits:
        header = f"[{h['file']} :: {h['title']}]"
        ctx_parts.append(header + "\n" + h["text"])
    ctx = "\n\n---\n\n".join(ctx_parts)
    return (
        f"Context from local Markdown files:\n\n{ctx}\n\n"
        f"Question: {query}\n\n"
        "Answer concisely and cite files/sections like [file :: heading]."
    )

