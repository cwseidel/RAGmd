def md_files():
    return sorted([
        p for ext in ("*.md", "*.Rmd", "*.qmd")
        for p in glob.glob(ext)
        if os.path.isfile(p)
    ])

def file_sig(path):
    st = os.stat(path)
    return f"{path}:{int(st.st_mtime)}:{st.st_size}"

def ensure_index_dir():
    os.makedirs(INDEX_DIR, exist_ok=True)

def chunk_text(text, filename):
    # Prefer splitting on headings; then window if needed.
    sections = re.split(r"(?m)^#{1,6}\s+", text)
    chunks = []
    for sec in sections:
        sec = sec.strip()
        if not sec:
            continue
        # further windowing by chars
        i = 0
        while i < len(sec):
            chunk = sec[i:i+CHUNK_SIZE]
            chunks.append(chunk)
            i += CHUNK_SIZE - CHUNK_OVERLAP
    # attach simple titles from preceding headings for context
    # (rough but effective)
    lines = text.splitlines()
    titles = []
    for i,l in enumerate(lines):
        if re.match(r"^#{1,6}\s+", l):
            titles.append((i, l.strip("# ").strip()))
    def nearest_title(pos):
        prev = [t for t in titles if t[0] <= pos]
        return prev[-1][1] if prev else pathlib.Path(filename).stem
    out = []
    pos = 0
    for c in chunks:
        # Find rough position to guess heading
        snippet_start = text.find(c, pos)
        title = nearest_title(snippet_start if snippet_start>=0 else pos)
        out.append({"file": filename, "title": title, "text": c})
        pos = (snippet_start + len(c)) if snippet_start>=0 else pos + len(c)
    return out

def build_corpus():
    data = []
    sigs = []
    for f in md_files():
        with open(f, "r", encoding="utf-8", errors="ignore") as fh:
            txt = fh.read()
        ch = chunk_text(txt, f)
        data.extend(ch)
        sigs.append(file_sig(f))
    return data, sigs

def load_or_build_index(force=False):
    ensure_index_dir()
    meta_path = os.path.join(INDEX_DIR, "meta.json")
    idx_path  = os.path.join(INDEX_DIR, "index.faiss")
    map_path  = os.path.join(INDEX_DIR, "map.json")

    current_sigs = [file_sig(f) for f in md_files()]

    if (not force and os.path.exists(meta_path) and os.path.exists(idx_path) and os.path.exists(map_path)):
        meta = json.load(open(meta_path))
        if meta.get("sigs") == current_sigs:
            # load
            index = faiss.read_index(idx_path)
            mapping = json.load(open(map_path))
            return index, mapping

    # (re)build
    console.print("[bold]Indexing Markdown...[/bold]")
    corpus, sigs = build_corpus()
    if len(corpus) == 0:
        raise SystemExit("No Markdown files found.")

    model = SentenceTransformer(EMB_MODEL)
    texts = [c["text"] for c in corpus]
    embs = model.encode(texts, batch_size=64, show_progress_bar=True, normalize_embeddings=True)

    index = faiss.IndexFlatIP(embs.shape[1])
    index.add(embs)

    # Save
    faiss.write_index(index, idx_path)
    json.dump({"sigs": sigs, "emb_model": EMB_MODEL, "ts": time.time()}, open(meta_path, "w"))
    json.dump(corpus, open(map_path, "w"))
    return index, corpus

def retrieve(query, top_k=TOP_K):
    index, mapping = load_or_build_index(force=False)
    model = SentenceTransformer(EMB_MODEL)
    q = model.encode([query], normalize_embeddings=True)
    D, I = index.search(q, top_k)
    hits = []
    for rank, (score, idx) in enumerate(zip(D[0], I[0]), start=1):
        if idx == -1: continue
        item = mapping[idx]
        hits.append({"rank": rank, "score": float(score), **item})
    return hits

